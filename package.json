{
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@qingshaner/eslint-config": "^2.0.0",
    "@types/node": "^25.9.4",
    "knip": "^6.23.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.4"
  },
  "keywords": [],
  "license": "ISC",
  "name": "shadcn-design-token",
  "nano-staged": {
    "*.{vue,svg,js,jsx,cjs,mjs,ts,tsx,cts,mts}": "pnpm biome check --write"
  },
  "private": true,
  "scripts": {
    "check": "pnpm biome check . --fix",
    "format": "biome format . --write",
    "lint": "biome lint . --write",
    "prepare": "simple-git-hooks",
    "registry:build": "pnpm registry:generate && npm exec --yes shadcn@latest -- build registry.json --output public/r",
    "registry:build:pages": "pnpm registry:generate && npm exec --yes shadcn@latest -- build registry.json --output packages/ui/storybook-static/r",
    "registry:generate": "node scripts/generate-shadcn-registry.mjs && pnpm biome format registry.json --write",
    "test": "pnpm --filter=ui test"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged",
    "pre-push": "pnpm test"
  },
  "type": "module",
  "version": "1.0.0"
}
