{
  "author": "",
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@qingshaner/eslint-config": "^2.0.0",
    "@types/node": "^25.9.4",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
